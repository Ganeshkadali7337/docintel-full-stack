# Environment variables for Document Intelligence Platform
# Copy this file to .env and fill in your actual values

# PostgreSQL database connection string
DATABASE_URL=postgresql://user:password@localhost:5432/docintel

# JWT secret key — must be at least 32 characters long, keep this private!
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters

# How long JWT tokens stay valid (e.g. 7d, 24h, 60m)
JWT_EXPIRES_IN=7d

# Cloudinary credentials — get these from cloudinary.com dashboard
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# The public URL of your app (used for redirects and CORS)
NEXT_PUBLIC_APP_URL=http://localhost:3000
